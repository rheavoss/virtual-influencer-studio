    "# CELL 4 — Download InstantID model weights (8GB total — takes ~8 min)\n",
    "from huggingface_hub import hf_hub_download, snapshot_download\n",
    "import os\n",
    "\n",
    "os.makedirs('/content/InstantID/checkpoints', exist_ok=True)\n",
    "os.makedirs('/content/InstantID/models/antelopev2', exist_ok=True)\n",
    "\n",
    "print('Downloading ip-adapter (~1.7GB)...')\n",
