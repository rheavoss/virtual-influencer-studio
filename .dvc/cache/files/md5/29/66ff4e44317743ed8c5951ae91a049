    "# CELL 5 — Load pipeline\n",
    "import os, sys, torch, cv2, numpy as np\n",
    "from PIL import Image\n",
    "from insightface.app import FaceAnalysis\n",
    "from diffusers import DDIMScheduler\n",
    "\n",
    "sys.path.insert(0, '/content/InstantID')\n",
    "from pipeline_stable_diffusion_xl_instantid import StableDiffusionXLInstantIDPipeline\n",
    "\n",
    "# Face analyser\n",
    "app = FaceAnalysis(name='antelopev2', root='/content/InstantID/models',\n",
    "                   providers=['CUDAExecutionProvider'])\n",
    "app.prepare(ctx_id=0, det_size=(640, 640))\n",
    "\n",
    "# Load base SDXL model + InstantID\n",
    "BASE = 'wangqixun/YamerMIX_v8'\n",
    "pipe = StableDiffusionXLInstantIDPipeline.from_pretrained(\n",
    "    BASE, torch_dtype=torch.float16, safety_checker=None).to('cuda')\n",
    "pipe.load_ip_adapter_instantid('/content/InstantID/checkpoints/ip-adapter.bin')\n",
    "pipe.scheduler = DDIMScheduler.from_pretrained(\n",
    "    BASE, subfolder='scheduler', timestep_spacing='leading', steps_offset=1)\n",
    "\n",
    "print('Pipeline loaded and ready')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# CELL 6 — Upload your reference face image\n",
    "from google.colab import files\n",
    "import io\n",
    "\n",
    "print('Upload jasmine_02_white_shirt_tied_smile.jpg now:')\n",
    "uploaded = files.upload()\n",
    "fname = list(uploaded.keys())[0]\n",
    "\n",
    "face_image = Image.open(io.BytesIO(uploaded[fname])).convert('RGB').resize((512, 768))\n",
    "face_cv   = cv2.cvtColor(np.array(face_image), cv2.COLOR_RGB2BGR)\n",
    "faces     = app.get(face_cv)\n",
    "\n",
    "assert faces, 'No face detected — use a clear frontal face crop'\n",
    "\n",
    "face_emb = torch.from_numpy(faces[0].normed_embedding).unsqueeze(0)\n",
    "print(f'Face locked from: {fname}')\n",
    "display(face_image)"
   ],
   "execution_count": null,
   "outputs": []
