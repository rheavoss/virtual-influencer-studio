    "# CELL 8 — Generate all 30 images\n",
    "import os\n",
    "from IPython.display import display\n",
    "\n",
    "OUT = '/content/jasmine_output'\n",
    "os.makedirs(OUT, exist_ok=True)\n",
    "\n",
    "pipe.set_ip_adapter_scale(0.8)\n",
    "\n",
    "for i, prompt in enumerate(PROMPTS):\n",
    "    print(f'[{i+1}/30] {prompt[:70]}')\n",
    "    img = pipe(\n",
    "        prompt=prompt,\n",
    "        negative_prompt=NEG,\n",
    "        image_embeds=face_emb,\n",
    "        image=face_image,\n",
    "        num_inference_steps=30,\n",
    "        guidance_scale=5.0,\n",
    "        width=512, height=768,\n",
    "    ).images[0]\n",
    "    path = f'{OUT}/jasmine_locked_{i+1:02d}.png'\n",
    "    img.save(path)\n",
    "    if (i+1) % 5 == 0:\n",
    "        display(img)\n",
    "        print(f'  saved: {path}')\n",
    "\n",
    "print('All 30 images generated')"
