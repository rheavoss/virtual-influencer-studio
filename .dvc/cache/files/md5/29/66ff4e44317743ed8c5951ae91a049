    "\n",
    "print('Downloading controlnet (~5.7GB)...')\n",
    "snapshot_download(repo_id='InstantX/InstantID',\n",
    "                  local_dir='/content/InstantID/checkpoints',\n",
    "                  ignore_patterns=['*.gguf', '*.md', '.gitattributes'])\n",
    "\n",
    "print('Downloading face analysis model (~500MB)...')\n",
    "snapshot_download(repo_id='DIAMONIK7777/antelopev2',\n",
    "                  local_dir='/content/InstantID/models/antelopev2')\n",
    "\n",
    "print('All models downloaded')"
